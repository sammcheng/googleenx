# Server Configuration
NODE_ENV=development
PORT=3000
HOST=0.0.0.0
API_VERSION=v1
SERVER_TIMEOUT=30000

# CORS Configuration
CORS_ORIGINS=

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# Optional Persistence
MONGODB_ENABLED=false
MONGODB_REQUIRED=false
REDIS_ENABLED=false
REDIS_REQUIRED=false

# Database Configuration
MONGODB_URI=
MONGODB_MAX_POOL_SIZE=10
MONGODB_SERVER_SELECTION_TIMEOUT=5000
MONGODB_SOCKET_TIMEOUT=45000

# Redis Configuration
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# Security Configuration
JWT_SECRET=replace-with-a-long-random-secret
JWT_EXPIRES_IN=24h
JWT_ISSUER=food-price-comparison-api
JWT_AUDIENCE=food-price-comparison-extension
BCRYPT_SALT_ROUNDS=12
API_KEY_HEADER=X-API-Key
API_KEY_VALUE=your-api-key-here

# Logging Configuration
LOG_LEVEL=info
LOG_FORMAT=combined
LOG_FILE_ENABLED=false
LOG_FILE_NAME=logs/app.log
LOG_FILE_MAX_SIZE=10m
LOG_FILE_MAX_FILES=5
LOG_CONSOLE_ENABLED=true
LOG_CONSOLE_COLORIZE=true

# External APIs
GOOGLE_MAPS_API_KEY=
OPENWEATHER_API_KEY=

# Food Delivery APIs
DOORDASH_API_URL=https://api.doordash.com
DOORDASH_API_KEY=
UBEREATS_API_URL=https://api.ubereats.com
UBEREATS_API_KEY=
GRUBHUB_API_URL=https://api.grubhub.com
GRUBHUB_API_KEY=

# Cache Configuration
CACHE_TTL=3600
CACHE_MAX_SIZE=100
CACHE_CHECK_PERIOD=600

# Monitoring Configuration
MONITORING_ENABLED=false
METRICS_ENABLED=false
METRICS_PORT=9090
HEALTH_CHECK_INTERVAL=30000
HEALTH_CHECK_TIMEOUT=5000

# Features Configuration
SCRAPING_ENABLED=true
SCRAPING_USER_AGENT=Food Price Comparison Bot 1.0
SCRAPING_DELAY=1000
SCRAPING_RETRIES=3

# Notifications Configuration
NOTIFICATIONS_ENABLED=false
EMAIL_NOTIFICATIONS_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
PUSH_NOTIFICATIONS_ENABLED=false
VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key

# Test Configuration (for testing environment)
MONGODB_TEST_URI=mongodb://localhost:27017/food-price-comparison-test
